{
  "name": "instasub-web-automation",
  "version": "1.0.0",
  "description": "Enterprise-grade Playwright automation suite for TimeClock Plus",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui",
    "test:debug": "npx playwright test --debug",
    "test:headed": "npx playwright test --headed",
    "test:chrome": "npx playwright test --project=chromium",
    "test:firefox": "npx playwright test --project=firefox",
    "test:webkit": "npx playwright test --project=webkit",
    "test:ise452": "npx playwright test tests/ISE-452-absence-creation.spec.ts",
    "test:ise1551": "npx playwright test ISE-1551 --project=chromium",
    "test:ise1551:headed": "npx playwright test ISE-1551 --project=chromium --headed --workers=1",
    "test:flaky": "npx playwright test --grep 'Flakiness|reliability'",
    "test:report": "npx playwright show-report",
    "test:layer5": "node scripts/run-tests.js",
    "test:layer5:compose": "node scripts/run-tests.js --compose",
    "agent:all": "node agents/orchestrate-all-layers.js",
    "agent:layer0": "node agents/agent-layer0-ticket-intake.js",
    "agent:layer1": "node agents/agent-layer1-requirements.js",
    "agent:layer2": "node agents/agent-layer2-strategy.js",
    "agent:layer3": "node agents/agent-layer3-context.js",
    "agent:layer4": "node agents/agent-layer4-codegen.js",
    "agent:layer5": "node agents/agent-layer5-execution.js",
    "agent:layer6": "node agents/agent-layer6-selfheal.js",
    "agent:intake": "node agents/agent-layer0-ticket-intake.js",
    "agent:requirements": "node agents/agent-layer1-requirements.js",
    "agent:strategy": "node agents/agent-layer2-strategy.js",
    "agent:context": "node agents/agent-layer3-context.js",
    "agent:codegen": "node agents/agent-layer4-codegen.js",
    "agent:execution": "node agents/agent-layer5-execution.js",
    "agent:selfheal": "node agents/agent-layer6-selfheal.js",
    "docker:build": "docker build -t instasub-playwright:latest .",
    "docker:run": "docker run --rm -it instasub-playwright:latest npm test",
    "docker:compose:up": "docker-compose up --abort-on-container-exit",
    "docker:compose:down": "docker-compose down",
    "vector-db:index": "node vector-db/retriever.js index",
    "vector-db:query": "node vector-db/retriever.js query",
    "vector-db:list": "node vector-db/retriever.js list",
    "jira:fetch": "node jira-fetch.js",
    "dev": "echo 'Start your dev server here'",
    "lint": "echo 'Add linting here'",
    "format": "prettier --write ."
  },
  "keywords": [
    "playwright",
    "automation",
    "testing",
    "e2e",
    "timeclock-plus"
  ],
  "author": "TCP QA Team",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.21.0",
    "@xenova/transformers": "^2.17.2",
    "axios": "^1.6.0",
    "pg": "^8.11.0",
    "dotenv": "^16.3.0"
  }
}
