# Copy to .env and fill in real values. Never commit the real .env.

# Jira Configuration
# Create API token at: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_DOMAIN=
JIRA_USER_EMAIL=
JIRA_API_TOKEN=""

# GitHub Configuration (for Layer 0: Ticket Intake & PR Creation)
# Create token at: https://github.com/settings/tokens
# GITHUB_OWNER: Your GitHub username (NOT email). Find it at: https://github.com/settings/profile
GITHUB_TOKEN=""
GITHUB_OWNER=
GITHUB_REPO=instasub-web-automation

# TimeClock Plus Test Credentials
PW_USERNAME=""
PW_PASSWORD=""
BASE_URL=
TICKET_NAME=
ABSENCE_EMPLOYEE_SEARCH=
ABSENCE_EMPLOYEE_LABEL=
